# Backend API URL (default for local development)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Set to 'false' to disable Google OAuth and bypass the login page
NEXT_PUBLIC_AUTH_ENABLED=false

# NextAuth Configuration (Required if AUTH_ENABLED=true)
NEXTAUTH_URL=http://localhost:3003
NEXTAUTH_SECRET=any_random_string_for_security
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
