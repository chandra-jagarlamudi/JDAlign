# Production Settings
# For local dev: *
# For production: https://your-frontend.vercel.app
ALLOWED_ORIGINS=*

# Authentication Toggle
# Set to 'false' to bypass the login page and use the app anonymously
NEXT_PUBLIC_AUTH_ENABLED=false

# Authentication (NextAuth - Required if NEXT_PUBLIC_AUTH_ENABLED=true)
# You must create a project at https://console.cloud.google.com
# Authorized Redirect URI: http://localhost:3003/api/auth/callback/google
NEXTAUTH_URL=http://localhost:3003
NEXTAUTH_SECRET=any_random_string_for_security
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# LLM Configuration
#
# Docker + Ollama on the host: set LLM_BASE_URL=http://host.docker.internal:11434
# (docker-compose already maps host.docker.internal). Native Python: localhost below.
#
# To use local Ollama:
LLM_MODEL=ollama/qwen3:8b-q4_K_M
LLM_BASE_URL=http://localhost:11434

# To use OpenRouter (works from Docker without extra compose config; needs a real key):
# LLM_MODEL=openrouter/anthropic/claude-3.5-sonnet
# LLM_BASE_URL=https://openrouter.ai/api/v1
# OPENROUTER_API_KEY=sk-or-v1-...

# Execution Control
MAX_ITERATIONS=3

# Observability (LangSmith) — optional, same outbound HTTPS as OpenRouter.
# If LANGCHAIN_TRACING_V2=true without a valid LANGCHAIN_API_KEY, LangSmith returns 401
# and you will see LangSmithAuthError noise in logs.
LANGCHAIN_TRACING_V2=false
# LANGCHAIN_API_KEY=
# LANGCHAIN_PROJECT=JDAlign
# LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
